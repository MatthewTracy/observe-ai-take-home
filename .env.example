# VAPI
VAPI_API_KEY=your_vapi_api_key_here
# Shared secret VAPI must send in the x-vapi-secret header on every webhook call.
# Configure the matching header in the VAPI assistant's Server URL settings.
# Generate with: openssl rand -hex 32
VAPI_WEBHOOK_SECRET=your_random_secret_here

# Airtable
AIRTABLE_PAT=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
AIRTABLE_CALLERS_TABLE=Callers
AIRTABLE_INTERACTIONS_TABLE=Interactions
